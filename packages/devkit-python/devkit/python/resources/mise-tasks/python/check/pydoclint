#!/usr/bin/env python3
"""Run pydoclint against the config shipped alongside this script.

The config path is resolved relative to this script's own location (not
the current working directory), so it works whether this file is reached
through the `.repolish/devkit-python/` whole-resources-directory symlink
(consumers installing devkit-python as a package) or a local monorepo path
(devkit dogfooding itself via `provider_root:`).
"""

import subprocess
import sys
from pathlib import Path

if __name__ == '__main__':
    config = Path(__file__).resolve().parents[3] / 'configs' / 'pydoclint.toml'
    cmd = ('pydoclint', '--style=google', f'--config={config}', '.')
    sys.exit(subprocess.run(cmd, check=False).returncode)
