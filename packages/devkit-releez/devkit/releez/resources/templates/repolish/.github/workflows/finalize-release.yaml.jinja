# generated by hotdog-werx/devkit — manual changes will be overwritten
name: Finalize release

on:
  pull_request:
    types:
      - closed

permissions:
  contents: write

jobs:
  finalize:
    name: Finalize release
    runs-on: ubuntu-latest
    if: >
      github.event.pull_request.merged == true &&
      startsWith(github.event.pull_request.head.ref, 'release/')
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install mise tools
        uses: jdx/mise-action@v3

      - name: Releez finalize
        id: releez
        {%- if use_self_action %}
        uses: ./
        {%- else %}
        uses: hotdog-werx/releez@{{ releez_action_version }}
        {%- endif %}
        with:
          mode: finalize

      - name: Set build version
        run: uv version {% raw %}${{ steps.releez.outputs.pep440-versions }}{% endraw %} --frozen

      - name: Build package
        run: {{ build_command }}

      - name: Publish to PyPI
        env:
          UV_PUBLISH_URL: {% raw %}${{ vars.PYPI_PUBLISH_URL }}{% endraw %}
          UV_PUBLISH_TOKEN: {% raw %}${{ secrets.PYPI_PUBLISH_TOKEN }}{% endraw %}
        run: {{ publish_command }}

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: {% raw %}${{ steps.releez.outputs.release-version }}{% endraw %}
          body: {% raw %}${{ steps.releez.outputs.release-notes }}{% endraw %}

