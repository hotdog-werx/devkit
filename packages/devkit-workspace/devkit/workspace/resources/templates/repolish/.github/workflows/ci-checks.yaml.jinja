# generated by hotdog-werx/devkit — manual changes will be overwritten
name: ci-checks

on:
  pull_request:
    branches: [master]
  push:
    branches: [master]

jobs:
  repo-checks:
    uses: hotdog-werx/devkit/.github/workflows/__workspace_repo-checks.yaml@{{ devkit_ref }}
    with:
      enable-docs: {{ enable_docs | lower }}
{% if has_python %}
  python-checks:
    uses: hotdog-werx/devkit/.github/workflows/__python_python-checks.yaml@{{ devkit_ref }}
    with:
      operating-systems: '{{ python_operating_systems | tojson }}'
      codecov: {{ python_codecov | lower }}
    secrets:
      CODECOV_TOKEN: {% raw %}${{ secrets.CODECOV_TOKEN }}{% endraw %}
{% endif %}
## repolish-keep-block[custom-ci-checks]: start="  ## start-custom-ci-checks" end="  ## end-custom-ci-checks"
  ## start-custom-ci-checks
  ## Add custom jobs here (e.g. a tests/test-action pair). Content between
  ## these two marker lines is preserved verbatim across repolish
  ## re-applies — GitHub Actions `needs:` only works between jobs in the
  ## same file, so jobs that must depend on repo-checks/python-checks
  ## belong here rather than in a separate workflow file.
  ##
  ## Both marker lines' leading indentation must stay exactly 2 spaces —
  ## dprint's yaml formatter pulls a comment sitting directly before/after
  ## an indented job key to match that indent, and repolish's marker
  ## lookup is an exact string match with no whitespace normalization. If
  ## only one marker drifts (e.g. nothing indented follows the end marker
  ## so dprint leaves it at column 0), the lookup silently stops matching.
  ## end-custom-ci-checks
