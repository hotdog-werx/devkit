#!/usr/bin/env python3
"""Install pnpm dependencies, if this project has any."""

import subprocess
import sys
from pathlib import Path

if __name__ == '__main__':
    if not Path('pnpm-lock.yaml').exists():
        print('skipping pnpm install, no pnpm-lock.yaml found')
        sys.exit(0)
    sys.exit(subprocess.run(('pnpm', 'install'), check=False).returncode)
