#!/usr/bin/env python3
"""Run full dev setup on `mise install`, except in CI (which runs its own steps)."""

import os
import subprocess
import sys

if __name__ == '__main__':
    if os.environ.get('CI', 'false') == 'true':
        print('skip dev setup in CI')
        sys.exit(0)
    sys.exit(subprocess.run(('mise', 'run', 'setup'), check=False).returncode)
