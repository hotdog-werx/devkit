#!/usr/bin/env bash
set -euo pipefail
if [ -f pyproject.toml ]; then
  # --all-packages is required for uv workspaces (devkit's own self-dogfood
  # is one) to actually install the workspace member packages as editable
  # installs — without it, e.g. `devkit.workspace`/`devkit.python` end up
  # unimportable even though `uv sync` "succeeds". It's a no-op for
  # single-project repos with no [tool.uv.workspace] members.
  uv sync --all-groups --all-packages
else
  echo "skipping uv sync, no pyproject.toml found"
fi
